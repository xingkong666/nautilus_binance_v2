# Binance API
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# Environment: dev / stage / prod
ENV=dev

# Runtime infrastructure
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/nautilus_trader
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Live launch overrides
EXCHANGE_ENVIRONMENT=
LIVE_STRATEGY_CONFIG=configs/strategies/vegas_tunnel.yaml
SUBMIT_ORDERS=false

# Telegram alerting (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Prometheus (optional)
PROMETHEUS_PORT=9100
